# Copy to .env and fill in values before running docker compose up.
# .env is gitignored — never commit it.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Rails master key — decrypts config/credentials/<environment>.yml.enc.
# Obtain from config/credentials/<environment>.key
RAILS_MASTER_KEY=

# ---------------------------------------------------------------------------
# Optional (defaults shown)
# ---------------------------------------------------------------------------

# Auto-delete notes older than this many days (default: 30)
# PURGE_NOTES_AFTER_DAYS=30

# Puma thread count; also sets the DB connection pool size (default: 3)
# RAILS_MAX_THREADS=3

# Puma worker processes — increase for multi-core hosts (default: 1)
# WEB_CONCURRENCY=1

# Rails log level: debug | info | warn | error | fatal (default: info)
RAILS_LOG_LEVEL=warn

# Thruster: set to your domain to enable automatic Let's Encrypt TLS.
# Requires ports 80 and 443 reachable from the internet and the 443:443
# port mapping uncommented in the compose file.
# TLS_DOMAIN=notes.example.com
