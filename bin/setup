#!/usr/bin/env -S bash -e
#
# Setup Ruby on Rails application
# Requirements:
#   mise-en-place version manager installed
#   Ruby 3.4.9 installable with mise (uses ruby-build)

MISE="$HOME/.local/bin/mise"
RAILS_ENV=production
RACK_ENV=production

echo "=== Running Bundle Install ==="
$MISE exec ruby@3.4.9 -- bundle

echo "=== Installing Thruster ==="
$MISE exec ruby@3.4.9 -- gem install thruster

echo "=== Preparing Database ==="
$MISE exec ruby@3.4.9 -- rails db:create

echo "=== Compiling Assets ==="
$MISE exec ruby@3.4.9 -- rails assets:precompile

echo "=== Setup Done ==="

